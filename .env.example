# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored so your local secrets stay out of source control.

# Supabase connection — for local dev, point at your self-hosted instance:
#   http://localhost:54341
# For production (Cloudflare Pages), these are set in the project env vars UI,
# pointing at the public tunnel URL (e.g. https://sfxlib-api.parasfx.com).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Cloudflare Turnstile site key — shown on the admin login page.
# Create one at https://dash.cloudflare.com/?to=/:account/turnstile
# This is the PUBLIC key (safe to expose). The matching secret lives in
# docker/.env as GOTRUE_SECURITY_CAPTCHA_SECRET.
VITE_TURNSTILE_SITE_KEY=
